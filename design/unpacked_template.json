36\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"b8309f44-438c-493f-83b3-122ea55b9448\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n\n<style>\n  :root{\n    --paper:#FBFAF7; --band:#F4F2EC; --card:#FFFFFF;\n    --hair:#E6E2D8; --hair-strong:#D6D2C6;\n    --ink:#1A1A17; --ink-2:#6C6A62; --ink-3:#9C9A8F;\n    --oxide:#C2410C; --steel:#33505E;\n    --good:#1F7A4D; --bad:#B42318; --warn:#9A6700;\n    --term-bg:#1A1A17; --term-ink:#E9E6DD;\n    --ease:cubic-bezier(.22,.61,.36,1);\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  body{\n    background:var(--paper);color:var(--ink);\n    font-family:\"Inter\",system-ui,sans-serif;font-size:15px;line-height:1.5;\n    -webkit-font-smoothing:antialiased;height:100vh;display:flex;flex-direction:column;overflow:hidden;\n  }\n  .mono{font-family:\"JetBrains Mono\",monospace}\n  h1,h2,h3{font-family:\"Instrument Serif\",Georgia,serif;font-weight:400;letter-spacing:-.01em;line-height:1.05}\n  button{font-family:inherit;cursor:pointer}\n  ::selection{background:rgba(194,65,12,.16)}\n\n  /* ---------- TOP BAR ---------- */\n  .topbar{\n    flex:0 0 auto;border-bottom:1px solid var(--hair);background:var(--paper);\n    display:flex;align-items:center;justify-content:space-between;gap:18px;\n    padding:14px 26px;font-family:\"JetBrains Mono\",monospace;\n  }\n  .brand{display:flex;align-items:baseline;gap:12px}\n  .brand .mark{font-size:13px;letter-spacing:.22em;font-weight:600}\n  .brand .sub{font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3)}\n  .topbar .controls{display:flex;align-items:center;gap:14px}\n\n  .conn{display:flex;align-items:center;gap:8px;font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3)}\n  .dot{width:8px;height:8px;border-radius:50%;background:var(--ink-3);transition:background .3s}\n  .dot.on{background:var(--good)}\n  .dot.run{background:var(--oxide);animation:pulse 1.1s var(--ease) infinite}\n  .dot.err{background:var(--bad)}\n  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.28}}\n\n  .btn{\n    font-family:\"JetBrains Mono\",monospace;font-size:11.5px;letter-spacing:.07em;text-transform:uppercase;\n    border:1px solid var(--hair-strong);background:var(--card);color:var(--ink);\n    padding:9px 16px;border-radius:3px;transition:all .18s var(--ease);\n  }\n  .btn:hover{border-color:var(--oxide);color:var(--oxide)}\n  .btn:disabled{opacity:.4;cursor:not-allowed;color:var(--ink);border-color:var(--hair)}\n  .btn.primary{background:var(--oxide);border-color:var(--oxide);color:#fff}\n  .btn.primary:hover{background:#a8360a;border-color:#a8360a;color:#fff}\n  .btn.primary:disabled{background:var(--hair);border-color:var(--hair);color:var(--ink-3)}\n  .btn.danger:hover{border-color:var(--bad);color:var(--bad)}\n\n  /* ---------- STAT STRIP ---------- */\n  .stats{\n    flex:0 0 auto;display:grid;grid-template-columns:repeat(4,1fr);\n    border-bottom:1px solid var(--hair);background:var(--band);\n  }\n  .stat{padding:14px 22px;border-right:1px solid var(--hair)}\n  .stat:last-child{border-right:none}\n  .stat .v{font-family:\"JetBrains Mono\",monospace;font-size:21px;font-weight:500;color:var(--oxide);letter-spacing:-.01em;line-height:1}\n  .stat .k{font-family:\"JetBrains Mono\",monospace;font-size:9.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-top:9px}\n\n  /* ---------- BODY GRID ---------- */\n  .main{flex:1 1 auto;display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,1fr);min-height:0}\n  @media(max-width:880px){\n    .main{grid-template-columns:1fr;overflow:auto}\n    body{overflow:auto;height:auto;min-height:100vh}\n  }\n\n  .pane{display:flex;flex-direction:column;min-height:0;min-width:0}\n  .pane.logs{border-right:1px solid var(--hair)}\n  .pane-head{\n    flex:0 0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px;\n    padding:13px 22px;border-bottom:1px solid var(--hair);background:var(--paper);\n  }\n  .pane-head .title{font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-2)}\n  .pane-head .meta{font-family:\"JetBrains Mono\",monospace;font-size:10px;letter-spacing:.05em;color:var(--ink-3)}\n\n  /* ---------- TERMINAL ---------- */\n  .term{\n    flex:1 1 auto;min-height:0;overflow:auto;background:var(--term-bg);color:var(--term-ink);\n    font-family:\"JetBrains Mono\",monospace;font-size:12.5px;line-height:1.62;padding:16px 20px;\n  }\n  @media(max-width:880px){.term{min-height:340px}}\n  .term .ln{white-space:pre-wrap;word-break:break-word}\n  .term .ln.cmd{color:#E8B98C}\n  .term .ln.srv{color:#8FA3AD}\n  .term .ln.ok{color:#7FCBA0}\n  .term .ln.err{color:#E89B92}\n  .term .empty{color:#6c6a62;font-style:italic}\n  .term::-webkit-scrollbar{width:10px}\n  .term::-webkit-scrollbar-thumb{background:#3a3a34;border-radius:5px}\n\n  /* ---------- TABS ---------- */\n  .tabs{flex:0 0 auto;display:flex;border-bottom:1px solid var(--hair);background:var(--paper)}\n  .tab{\n    font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.09em;text-transform:uppercase;\n    padding:13px 20px;border:none;background:none;color:var(--ink-3);border-bottom:2px solid transparent;margin-bottom:-1px;\n  }\n  .tab.active{color:var(--ink);border-bottom-color:var(--oxide)}\n  .tab .c{color:var(--oxide);margin-left:6px}\n  .panel{flex:1 1 auto;min-height:0;overflow:auto;padding:18px 22px}\n  @media(max-width:880px){.panel{min-height:300px}}\n  .panel.hidden{display:none}\n\n  /* ---------- FAKE CARDS ---------- */\n  .fake{border:1px solid var(--hair);border-radius:3px;background:var(--card);padding:15px 17px;margin-bottom:12px}\n  .fake .top{display:flex;align-items:center;gap:9px;flex-wrap:wrap;margin-bottom:10px}\n  .tag{font-family:\"JetBrains Mono\",monospace;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:3px 8px;border-radius:3px;border:1px solid var(--hair-strong);color:var(--ink-2)}\n  .tag.fake{color:var(--bad);border-color:rgba(180,35,24,.3);background:rgba(180,35,24,.05)}\n  .tag.real{color:var(--good);border-color:rgba(31,122,77,.3);background:rgba(31,122,77,.05)}\n  .tag.caught{color:var(--good);border-color:rgba(31,122,77,.3)}\n  .tag.missed{color:var(--oxide);border-color:rgba(194,65,12,.35);background:rgba(194,65,12,.05)}\n  .tag.rnd{color:var(--steel);border-color:rgba(51,80,94,.3)}\n  .fake .body{font-size:14px;line-height:1.6;color:var(--ink);text-wrap:pretty}\n  .fake .conf{margin-left:auto;font-family:\"JetBrains Mono\",monospace;font-size:11px;color:var(--ink-3)}\n\n  /* ---------- RULE CARDS ---------- */\n  .rule{border:1px solid var(--hair);border-left:2px solid var(--oxide);border-radius:3px;background:var(--card);padding:14px 17px;margin-bottom:11px}\n  .rule .rh{display:flex;align-items:baseline;gap:10px;margin-bottom:7px}\n  .rule .rid{font-family:\"JetBrains Mono\",monospace;font-size:10px;letter-spacing:.05em;color:var(--oxide)}\n  .rule .rrnd{font-family:\"JetBrains Mono\",monospace;font-size:9.5px;letter-spacing:.05em;color:var(--ink-3);margin-left:auto}\n  .rule .rbody{font-size:14px;line-height:1.6;color:var(--ink);text-wrap:pretty}\n  .rule pre,.raw{white-space:pre-wrap;word-break:break-word;font-family:\"JetBrains Mono\",monospace;font-size:12.5px;line-height:1.6;color:var(--ink)}\n\n  .kv{display:flex;gap:8px;font-family:\"JetBrains Mono\",monospace;font-size:11px;color:var(--ink-2);margin-top:4px}\n  .kv b{color:var(--ink-3);font-weight:500;min-width:96px;display:inline-block}\n\n  .empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;text-align:center;color:var(--ink-3);padding:40px}\n  .empty-state h3{font-size:24px;color:var(--ink-2)}\n  .empty-state p{font-size:13px;max-width:34ch;line-height:1.55}\n\n  /* settings popover */\n  .gear{font-size:14px;color:var(--ink-3);background:none;border:none;padding:4px}\n  .gear:hover{color:var(--oxide)}\n  .setrow{display:flex;align-items:center;gap:10px;font-family:\"JetBrains Mono\",monospace;font-size:11px}\n  .setrow input{font-family:\"JetBrains Mono\",monospace;font-size:11px;padding:7px 10px;border:1px solid var(--hair-strong);border-radius:3px;width:230px;background:var(--card);color:var(--ink)}\n  .setbar{flex:0 0 auto;display:none;gap:14px;align-items:center;padding:11px 22px;border-bottom:1px solid var(--hair);background:var(--band)}\n  .setbar.show{display:flex}\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n\n<!-- TOP BAR -->\n<div class=\"topbar\">\n  <div class=\"brand\">\n    <span class=\"mark\">CRUCIBLE<\u002Fspan>\n    <span class=\"sub\">Eval Console<\u002Fspan>\n  <\u002Fdiv>\n  <div class=\"controls\">\n    <div class=\"conn\"><span class=\"dot\" id=\"dot\"><\u002Fspan><span id=\"connText\">connecting…<\u002Fspan><\u002Fdiv>\n    <button class=\"gear\" id=\"gearBtn\" title=\"Server settings\">⚙<\u002Fbutton>\n    <button class=\"btn danger\" id=\"stopBtn\" disabled=\"\">■ Stop<\u002Fbutton>\n    <button class=\"btn primary\" id=\"runBtn\" disabled=\"\">▸ Run pipeline<\u002Fbutton>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- SETTINGS -->\n<div class=\"setbar\" id=\"setbar\">\n  <div class=\"setrow\">\n    <span>API base<\u002Fspan>\n    <input id=\"apiInput\" placeholder=\"http://localhost:5000\">\n    <button class=\"btn\" id=\"apiSave\">Save &amp; reconnect<\u002Fbutton>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- STATS -->\n<div class=\"stats\">\n  <div class=\"stat\"><div class=\"v\" id=\"sStatus\">idle<\u002Fdiv><div class=\"k\">status<\u002Fdiv><\u002Fdiv>\n  <div class=\"stat\"><div class=\"v\" id=\"sFakes\">—<\u002Fdiv><div class=\"k\">fakes generated<\u002Fdiv><\u002Fdiv>\n  <div class=\"stat\"><div class=\"v\" id=\"sRules\">—<\u002Fdiv><div class=\"k\">learned rules<\u002Fdiv><\u002Fdiv>\n  <div class=\"stat\"><div class=\"v\" id=\"sLines\">0<\u002Fdiv><div class=\"k\">log lines<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n\n<!-- MAIN -->\n<div class=\"main\">\n  <!-- LOGS -->\n  <div class=\"pane logs\">\n    <div class=\"pane-head\">\n      <span class=\"title\">Pipeline logs<\u002Fspan>\n      <span class=\"meta\" id=\"logMeta\">live · stdout<\u002Fspan>\n    <\u002Fdiv>\n    <div class=\"term\" id=\"term\"><div class=\"empty\">No run yet. Press ▸ Run pipeline to start eval.py.<\u002Fdiv><\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- RESULTS -->\n  <div class=\"pane\">\n    <div class=\"tabs\">\n      <button class=\"tab active\" data-tab=\"fakes\">Generated fakes<span class=\"c\" id=\"tFakes\"><\u002Fspan><\u002Fbutton>\n      <button class=\"tab\" data-tab=\"rules\">Learning rules<span class=\"c\" id=\"tRules\"><\u002Fspan><\u002Fbutton>\n    <\u002Fdiv>\n    <div class=\"panel\" id=\"panel-fakes\">\n      <div class=\"empty-state\"><h3>No fakes yet<\u002Fh3><p>Generated fakes appear here once a run produces them.<\u002Fp><\u002Fdiv>\n    <\u002Fdiv>\n    <div class=\"panel hidden\" id=\"panel-rules\">\n      <div class=\"empty-state\"><h3>No rules yet<\u002Fh3><p>The detector's rewritten rules show up here after it diagnoses its misses.<\u002Fp><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<script>\n(function(){\n  // ---- API base (works served by Flask OR opened from disk) ----\n  function defaultBase(){\n    if(location.protocol === \"file:\") return \"http://localhost:5000\";\n    return location.origin;\n  }\n  let API = localStorage.getItem(\"crucible_api\") || defaultBase();\n\n  const $ = s => document.querySelector(s);\n  const term = $(\"#term\"), dot = $(\"#dot\"), connText = $(\"#connText\");\n  const runBtn = $(\"#runBtn\"), stopBtn = $(\"#stopBtn\");\n  let es = null, atBottom = true, started = false;\n\n  // autoscroll only if user is at the bottom\n  term.addEventListener(\"scroll\", () => {\n    atBottom = term.scrollHeight - term.scrollTop - term.clientHeight < 40;\n  });\n\n  function classify(line){\n    if(line.startsWith(\"$ \")) return \"cmd\";\n    if(line.startsWith(\"[server]\")){\n      if(/finished|exit code 0/.test(line)) return \"ok\";\n      if(/error|could not/.test(line)) return \"err\";\n      return \"srv\";\n    }\n    if(/\\b(error|traceback|failed|exception)\\b/i.test(line)) return \"err\";\n    return \"\";\n  }\n\n  function addLine(line){\n    if(line === \"__CRUCIBLE_DONE__\"){ onDone(); return; }\n    if(!started){ term.innerHTML = \"\"; started = true; }\n    const div = document.createElement(\"div\");\n    div.className = \"ln \" + classify(line);\n    div.textContent = line || \"\\u00A0\";\n    term.appendChild(div);\n    $(\"#sLines\").textContent = term.querySelectorAll(\".ln\").length;\n    if(atBottom) term.scrollTop = term.scrollHeight;\n  }\n\n  function setConn(state, text){\n    dot.className = \"dot\" + (state ? \" \" + state : \"\");\n    connText.textContent = text;\n  }\n\n  // ---- SSE log stream ----\n  function connect(){\n    if(es) es.close();\n    setConn(\"\", \"connecting…\");\n    es = new EventSource(API + \"/api/stream\");\n    es.onopen = () => { setConn(\"on\", \"connected\"); pollStatus(); };\n    es.onmessage = e => { try{ addLine(JSON.parse(e.data).line); }catch(_){} };\n    es.onerror = () => { setConn(\"err\", \"server offline\"); runBtn.disabled = true; };\n  }\n\n  async function pollStatus(){\n    try{\n      const r = await fetch(API + \"/api/status\");\n      const s = await r.json();\n      $(\"#sLines\").textContent = s.lines;\n      if(s.running){\n        setConn(\"run\", \"running\");\n        $(\"#sStatus\").textContent = \"running\";\n        runBtn.disabled = true; stopBtn.disabled = false;\n      } else {\n        setConn(\"on\", \"connected\");\n        runBtn.disabled = false; stopBtn.disabled = true;\n        if(s.returncode === null) $(\"#sStatus\").textContent = \"idle\";\n        else $(\"#sStatus\").textContent = s.returncode === 0 ? \"done\" : \"failed\";\n        if(s.returncode !== null){\n          $(\"#sStatus\").style.color = s.returncode === 0 ? \"var(--good)\" : \"var(--bad)\";\n        }\n      }\n    }catch(_){ setConn(\"err\",\"server offline\"); runBtn.disabled = true; }\n  }\n\n  runBtn.addEventListener(\"click\", async () => {\n    started = false;\n    runBtn.disabled = true;\n    try{\n      const r = await fetch(API + \"/api/run\", {method:\"POST\"});\n      const j = await r.json();\n      if(!j.ok){ alert(j.error || \"Could not start run.\"); runBtn.disabled = false; return; }\n      $(\"#sStatus\").textContent = \"running\"; $(\"#sStatus\").style.color = \"var(--oxide)\";\n      setConn(\"run\",\"running\"); stopBtn.disabled = false;\n    }catch(e){ alert(\"Server offline — is eval_server.py running?\"); runBtn.disabled = false; }\n  });\n\n  stopBtn.addEventListener(\"click\", async () => {\n    stopBtn.disabled = true;\n    try{ await fetch(API + \"/api/stop\", {method:\"POST\"}); }catch(_){}\n  });\n\n  function onDone(){\n    pollStatus();\n    loadResults();\n  }\n\n  // ---- results ----\n  async function loadResults(){\n    try{\n      const [fr, rr] = await Promise.all([\n        fetch(API + \"/api/fakes\").then(r=>r.json()),\n        fetch(API + \"/api/rules\").then(r=>r.json())\n      ]);\n      renderFakes(fr); renderRules(rr);\n    }catch(_){}\n  }\n\n  function pick(o, keys){ for(const k of keys) if(o && o[k]!=null) return o[k]; return undefined; }\n\n  function renderFakes(items){\n    const panel = $(\"#panel-fakes\");\n    $(\"#sFakes\").textContent = items.length;\n    $(\"#tFakes\").textContent = items.length ? \"· \" + items.length : \"\";\n    if(!items.length){\n      panel.innerHTML = '<div class=\"empty-state\"><h3>No fakes yet<\u002Fh3><p>Generated fakes appear here once a run produces them.<\u002Fp><\u002Fdiv>';\n      return;\n    }\n    panel.innerHTML = \"\";\n    items.forEach(it => {\n      const text  = pick(it, [\"text\",\"review\",\"content\",\"body\",\"fake\",\"output\"]);\n      const truth = pick(it, [\"true_label\",\"label\",\"truth\",\"is_fake\"]);\n      const pred  = pick(it, [\"predicted\",\"prediction\",\"pred\",\"detected\"]);\n      const conf  = pick(it, [\"confidence\",\"conf\",\"score\",\"prob\"]);\n      const round = pick(it, [\"round\",\"iteration\",\"it\",\"step\"]);\n      const card = document.createElement(\"div\");\n      card.className = \"fake\";\n      let top = \"\";\n      if(round!=null) top += `<span class=\"tag rnd\">RND ${round}<\u002Fspan>`;\n      if(truth!=null){\n        const isFake = String(truth).toLowerCase().match(/fake|1|true|deceptive/);\n        top += `<span class=\"tag ${isFake?'fake':'real'}\">${isFake?'FAKE':'REAL'}<\u002Fspan>`;\n      }\n      if(pred!=null && truth!=null){\n        const caught = String(pred).toLowerCase() === String(truth).toLowerCase()\n                    || (String(pred).match(/fake|1|true/) && String(truth).match(/fake|1|true/));\n        top += `<span class=\"tag ${caught?'caught':'missed'}\">${caught?'CAUGHT':'MISSED'}<\u002Fspan>`;\n      }\n      if(conf!=null) top += `<span class=\"conf\">conf ${typeof conf==='number'?conf.toFixed(2):conf}<\u002Fspan>`;\n      card.innerHTML = (top?`<div class=\"top\">${top}<\u002Fdiv>`:\"\") +\n        `<div class=\"body\">${esc(text!=null?text:JSON.stringify(it))}<\u002Fdiv>`;\n      // any extra fields → key/value rows\n      const known = [\"text\",\"review\",\"content\",\"body\",\"fake\",\"output\",\"true_label\",\"label\",\"truth\",\"is_fake\",\"predicted\",\"prediction\",\"pred\",\"detected\",\"confidence\",\"conf\",\"score\",\"prob\",\"round\",\"iteration\",\"it\",\"step\"];\n      Object.keys(it).filter(k=>!known.includes(k)).slice(0,4).forEach(k=>{\n        card.innerHTML += `<div class=\"kv\"><b>${esc(k)}<\u002Fb><span>${esc(String(it[k]))}<\u002Fspan><\u002Fdiv>`;\n      });\n      panel.appendChild(card);\n    });\n  }\n\n  function renderRules(items){\n    const panel = $(\"#panel-rules\");\n    $(\"#sRules\").textContent = items.length;\n    $(\"#tRules\").textContent = items.length ? \"· \" + items.length : \"\";\n    if(!items.length){\n      panel.innerHTML = '<div class=\"empty-state\"><h3>No rules yet<\u002Fh3><p>The detector\\'s rewritten rules show up here after it diagnoses its misses.<\u002Fp><\u002Fdiv>';\n      return;\n    }\n    // single text blob (markdown / txt)\n    if(items.length===1 && items[0].text!=null && Object.keys(items[0]).length===1){\n      panel.innerHTML = `<div class=\"rule\"><div class=\"raw\">${esc(items[0].text)}<\u002Fdiv><\u002Fdiv>`;\n      return;\n    }\n    panel.innerHTML = \"\";\n    items.forEach((it,i) => {\n      const body  = pick(it, [\"rule\",\"text\",\"description\",\"desc\",\"content\"]);\n      const id    = pick(it, [\"id\",\"name\",\"key\"]) || (\"R\" + String(i+1).padStart(2,\"0\"));\n      const round = pick(it, [\"round\",\"iteration\",\"it\",\"added\"]);\n      const card = document.createElement(\"div\");\n      card.className = \"rule\";\n      card.innerHTML =\n        `<div class=\"rh\"><span class=\"rid\">${esc(String(id))}<\u002Fspan>` +\n        (round!=null?`<span class=\"rrnd\">round ${esc(String(round))}<\u002Fspan>`:\"\") + `<\u002Fdiv>` +\n        `<div class=\"rbody\">${esc(body!=null?String(body):JSON.stringify(it))}<\u002Fdiv>`;\n      panel.appendChild(card);\n    });\n  }\n\n  function esc(s){ return String(s).replace(/[&<>]/g, c=>({\"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\"}[c])); }\n\n  // ---- tabs ----\n  document.querySelectorAll(\".tab\").forEach(t => t.addEventListener(\"click\", () => {\n    document.querySelectorAll(\".tab\").forEach(x=>x.classList.remove(\"active\"));\n    t.classList.add(\"active\");\n    $(\"#panel-fakes\").classList.toggle(\"hidden\", t.dataset.tab!==\"fakes\");\n    $(\"#panel-rules\").classList.toggle(\"hidden\", t.dataset.tab!==\"rules\");\n  }));\n\n  // ---- settings ----\n  $(\"#gearBtn\").addEventListener(\"click\", () => {\n    const bar = $(\"#setbar\"); bar.classList.toggle(\"show\");\n    $(\"#apiInput\").value = API;\n  });\n  $(\"#apiSave\").addEventListener(\"click\", () => {\n    API = $(\"#apiInput\").value.trim().replace(/\\/$/,\"\") || defaultBase();\n    localStorage.setItem(\"crucible_api\", API);\n    $(\"#setbar\").classList.remove(\"show\");\n    connect(); loadResults();\n  });\n\n  // ---- boot ----\n  connect();\n  loadResults();\n  setInterval(() => { if(!es || es.readyState!==1) connect(); }, 4000);\n})();\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  