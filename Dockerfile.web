# Dockerfile for the Crucible single-page LIVE DEMO (crucible.app.main:app).
# Includes Python + Node.js (Node is needed so the Reflector can spawn
# `npx @arizeai/phoenix-mcp` at runtime).

FROM python:3.11-slim

# --- Node.js 20 (for the Arize Phoenix MCP server via npx) ---
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- Python deps (full requirements: gemini, google-adk, phoenix, etc.) ---
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# --- App code ---
COPY crucible/ crucible/

# Warm the Phoenix MCP package so the first reflection call is fast
RUN npx -y @arizeai/phoenix-mcp@latest --version || true

# Cloud Run provides $PORT (defaults to 8080). Use shell form so it expands.
ENV PORT=8080
CMD exec uvicorn crucible.app.main:app --host 0.0.0.0 --port ${PORT}
