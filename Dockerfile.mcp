FROM python:3.11-slim

# Install Node.js for npx (required to spawn @arizeai/phoenix-mcp)
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install ONLY the minimal Python deps needed for the SSE proxy
RUN pip install --no-cache-dir \
    mcp \
    starlette \
    sse-starlette \
    uvicorn \
    httpx

# Copy only the wrapper code
COPY crucible/__init__.py crucible/__init__.py
COPY crucible/obs/__init__.py crucible/obs/__init__.py
COPY crucible/obs/mcp_cloud_run_wrapper.py crucible/obs/mcp_cloud_run_wrapper.py

# Pre-install the Phoenix MCP package so first call is fast
RUN npx -y @arizeai/phoenix-mcp@latest --version || true

EXPOSE 8080

# Run the self-contained MCP SSE proxy via uvicorn
CMD ["uvicorn", "crucible.obs.mcp_cloud_run_wrapper:app", "--host", "0.0.0.0", "--port", "8080"]
