FROM python:3.11-slim

# Install Node.js for npx (required to spawn @arizeai/phoenix-mcp)
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install ONLY the minimal Python deps for the Streamable HTTP proxy
RUN pip install --no-cache-dir \
    "mcp[cli]" \
    starlette \
    uvicorn \
    httpx

# Copy only the wrapper code (no agent dependencies needed)
COPY crucible/__init__.py crucible/__init__.py
COPY crucible/obs/__init__.py crucible/obs/__init__.py
COPY crucible/obs/mcp_cloud_run_wrapper.py crucible/obs/mcp_cloud_run_wrapper.py

# Pre-install the Phoenix MCP npm package so first call is fast
RUN npx -y @arizeai/phoenix-mcp@latest --version || true

EXPOSE 8080

# Run via python -m so the __main__ block starts the streamable-http server
CMD ["python", "-m", "crucible.obs.mcp_cloud_run_wrapper"]
